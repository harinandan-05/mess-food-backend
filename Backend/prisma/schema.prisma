generator client {
  provider = "prisma-client"
}

datasource db {
  provider = "postgresql"
}

model MessEntry {
  id             String   @id @default(uuid())
  date           String   // Storing as YYYY-MM-DD to match frontend DailyEntry
  dayOfWeek      String
  mealtype       String
  studentsTotal  Int
  studentsAte    Int
  foodpreparedkg Float
  foodwastedKg   Float
  createdAt      DateTime @default(now())
}

model Menu {
  id        String   @id @default(uuid())
  dayOfWeek String   // e.g. "Monday", "Tuesday"
  mealType  String   // e.g. "Breakfast", "Lunch", "Dinner"
  items     String  
  createdAt DateTime @default(now())

  @@unique([dayOfWeek, mealType])
}